[
  {
    "op": "list_add",
    "path": "services.api.cap_drop",
    "value": "ALL",
    "rule_id": "AC-SWM-CAPDROP"
  },
  {
    "op": "list_add",
    "path": "services.worker.cap_drop",
    "value": "ALL",
    "rule_id": "AC-SWM-CAPDROP"
  },
  {
    "op": "set",
    "path": "services.api.image",
    "value": "nginx:1.27@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
    "rule_id": "AC-SWM-DIGEST"
  },
  {
    "op": "set",
    "path": "services.worker.image",
    "value": "redis:7.2@sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
    "rule_id": "AC-SWM-DIGEST"
  },
  {
    "op": "set",
    "path": "services.api.healthcheck",
    "value": {
      "interval": "10s",
      "retries": 3,
      "start_period": "10s",
      "test": [
        "CMD",
        "nginx",
        "-t"
      ],
      "timeout": "5s"
    },
    "rule_id": "AC-SWM-HEALTH"
  },
  {
    "op": "set",
    "path": "services.worker.healthcheck",
    "value": {
      "interval": "10s",
      "retries": 5,
      "start_period": "10s",
      "test": [
        "CMD",
        "redis-cli",
        "ping"
      ],
      "timeout": "5s"
    },
    "rule_id": "AC-SWM-HEALTH"
  },
  {
    "op": "list_add",
    "path": "services.api.security_opt",
    "value": "no-new-privileges:true",
    "rule_id": "AC-SWM-NNP"
  },
  {
    "op": "list_add",
    "path": "services.worker.security_opt",
    "value": "no-new-privileges:true",
    "rule_id": "AC-SWM-NNP"
  },
  {
    "op": "set",
    "path": "services.api.read_only",
    "value": true,
    "rule_id": "AC-SWM-READONLY"
  },
  {
    "op": "set",
    "path": "services.worker.read_only",
    "value": true,
    "rule_id": "AC-SWM-READONLY"
  },
  {
    "op": "set",
    "path": "services.api.deploy.resources.limits.cpus",
    "value": "1.0",
    "rule_id": "AC-SWM-RESOURCES"
  },
  {
    "op": "set",
    "path": "services.api.deploy.resources.limits.memory",
    "value": "512m",
    "rule_id": "AC-SWM-RESOURCES"
  },
  {
    "op": "set",
    "path": "services.worker.deploy.resources.limits.cpus",
    "value": "1.0",
    "rule_id": "AC-SWM-RESOURCES"
  },
  {
    "op": "set",
    "path": "services.worker.deploy.resources.limits.memory",
    "value": "512m",
    "rule_id": "AC-SWM-RESOURCES"
  },
  {
    "op": "list_add",
    "path": "services.api.tmpfs",
    "value": "/run:rw,noexec,nosuid,nodev,size=16m",
    "rule_id": "AC-SWM-WRITABLE"
  },
  {
    "op": "list_add",
    "path": "services.api.tmpfs",
    "value": "/tmp:rw,noexec,nosuid,nodev,size=64m",
    "rule_id": "AC-SWM-WRITABLE"
  },
  {
    "op": "list_add",
    "path": "services.api.tmpfs",
    "value": "/var/run:rw,noexec,nosuid,nodev,size=16m",
    "rule_id": "AC-SWM-WRITABLE"
  },
  {
    "op": "list_add",
    "path": "services.worker.tmpfs",
    "value": "/run:rw,noexec,nosuid,nodev,size=16m",
    "rule_id": "AC-SWM-WRITABLE"
  },
  {
    "op": "list_add",
    "path": "services.worker.tmpfs",
    "value": "/tmp:rw,noexec,nosuid,nodev,size=64m",
    "rule_id": "AC-SWM-WRITABLE"
  },
  {
    "op": "list_add",
    "path": "services.worker.tmpfs",
    "value": "/var/run:rw,noexec,nosuid,nodev,size=16m",
    "rule_id": "AC-SWM-WRITABLE"
  }
]

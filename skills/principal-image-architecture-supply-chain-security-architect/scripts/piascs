#!/usr/bin/env sh
set -eu

script_path="$0"

case "$script_path" in
  */*) : ;;
  *)
    resolved="$(command -v -- "$script_path" 2>/dev/null || true)"
    case "$resolved" in
      */*) script_path="$resolved" ;;
    esac
    ;;
esac

if command -v readlink >/dev/null 2>&1; then
  while [ -L "$script_path" ]; do
    link="$(readlink "$script_path" 2>/dev/null || true)"
    [ -n "$link" ] || break
    case "$link" in
      /*) script_path="$link" ;;
      *) script_path="$(dirname -- "$script_path")/$link" ;;
    esac
  done
fi

script_dir="$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd)"
src_dir="${script_dir}/piascs-src"
bin="${src_dir}/target/release/piascs"

if [ ! -f "${src_dir}/Cargo.lock" ]; then
  echo "error: missing ${src_dir}/Cargo.lock" >&2
  exit 2
fi

needs_build=0
if [ ! -x "${bin}" ]; then
  needs_build=1
elif [ "${src_dir}/Cargo.toml" -nt "${bin}" ] || [ "${src_dir}/Cargo.lock" -nt "${bin}" ]; then
  needs_build=1
elif find "${src_dir}/src" -type f -newer "${bin}" -print -quit 2>/dev/null | grep -q .; then
  needs_build=1
fi

if [ "${needs_build}" -eq 1 ]; then
  if ! command -v cargo >/dev/null 2>&1; then
    echo "error: piascs is not built and cargo was not found in PATH" >&2
    exit 127
  fi
  cargo build --manifest-path "${src_dir}/Cargo.toml" --locked --release
fi

exec "${bin}" "$@"

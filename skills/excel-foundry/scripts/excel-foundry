#!/usr/bin/env sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  excel-foundry <inspect|query|push|pull|roundtrip|smoke|refresh|bootstrap|plan|compare|sync> [options]
  excel-foundry <sheet|name|table|query|cell|range> <action> [options]

Options:
  --manifest-path PATH
  --workbook-path PATH
  --output-dir PATH
  --query-name NAME
  --surface LIST
  --backend NAME
  --mode NAME
  --sheet NAME
  --table NAME
  --name NAME
  --name-prefix NAME
  --address A1
  --range-ref A1:B2
  --value-json JSON
  --values-json JSON
  --refers-to FORMULA
  --hidden
  --state-root PATH
  --apply
  --visible
  --help

This POSIX entrypoint is the user-facing CLI for bash, Git Bash, and WSL.
It validates arguments, normalizes paths, and bridges to the Windows
PowerShell backend for Excel COM automation.
EOF
}

script_path="$0"
case "$script_path" in
  */*) : ;;
  *) resolved="$(command -v -- "$script_path" 2>/dev/null || true)"; [ -n "$resolved" ] && script_path="$resolved" ;;
esac

if command -v readlink >/dev/null 2>&1; then
  while [ -L "$script_path" ]; do
    link="$(readlink "$script_path" 2>/dev/null || true)"
    [ -n "$link" ] || break
    case "$link" in
      /*) script_path="$link" ;;
      *) script_path="$(dirname -- "$script_path")/$link" ;;
    esac
  done
fi

script_dir="$(CDPATH='' cd -- "$(dirname -- "$script_path")" && pwd)"
ps1="${script_dir}/excel-foundry.ps1"

detect_powershell() {
  if [ "${EXCEL_WORKBOOK_SYNC_POWERSHELL:-}" ]; then
    printf '%s\n' "${EXCEL_WORKBOOK_SYNC_POWERSHELL}"
    return 0
  fi
  for candidate in pwsh powershell.exe powershell; do
    if command -v "$candidate" >/dev/null 2>&1; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

convert_path_arg() {
  value="$1"
  case "$value" in
    [A-Za-z]:\\*|[A-Za-z]:/*)
      printf '%s\n' "$value"
      return 0
      ;;
  esac
  if command -v wslpath >/dev/null 2>&1; then
    wslpath -w "$value"
    return 0
  fi
  if command -v cygpath >/dev/null 2>&1; then
    cygpath -w "$value"
    return 0
  fi
  printf '%s\n' "$value"
}

subcommand="${1:-}"
case "$subcommand" in
  ""|-h|--help|help)
    usage
    exit 0
    ;;
  query)
    if [ "${2:-}" = "list" ]; then
      subcommand="query-list"
      shift 2
    else
      shift
    fi
    ;;
  inspect|push|pull|roundtrip|smoke|refresh|plan|compare|sync)
    shift
    ;;
  bootstrap)
    shift
    ;;
  sheet|name|table|cell|range)
    action="${2:-}"
    [ -n "$action" ] || { echo "error: missing action for resource command: $subcommand" >&2; exit 2; }
    case "${subcommand}:${action}" in
      sheet:list|sheet:create|name:list|name:set|name:delete|table:list|table:read|cell:get|cell:set|range:get|range:set)
        subcommand="${subcommand}-${action}"
        shift 2
        ;;
      *)
        echo "error: unknown action '$action' for resource '$subcommand'" >&2
        exit 2
        ;;
    esac
    ;;
  *)
    echo "error: unknown subcommand: $subcommand" >&2
    echo "hint: use one of inspect, query, push, pull, roundtrip, smoke, refresh, bootstrap, plan, compare, sync, or resource commands like 'sheet list'" >&2
    exit 2
    ;;
esac

set -- "$@"
translated="$subcommand"
while [ "$#" -gt 0 ]; do
  arg="$1"
  shift
  case "$arg" in
    --help|-h)
      usage
      exit 0
      ;;
    --manifest-path|-ManifestPath)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      value="$(convert_path_arg "$1")"
      shift
      translated="${translated}
-ManifestPath
$value"
      ;;
    --workbook-path|-WorkbookPath)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      value="$(convert_path_arg "$1")"
      shift
      translated="${translated}
-WorkbookPath
$value"
      ;;
    --output-dir|-OutputDir)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      value="$(convert_path_arg "$1")"
      shift
      translated="${translated}
-OutputDir
$value"
      ;;
    --surface|-Surface)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      translated="${translated}
-Surface
$1"
      shift
      ;;
    --mode|-Mode)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      translated="${translated}
-Mode
$1"
      shift
      ;;
    --sheet|-Sheet)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      translated="${translated}
-Sheet
$1"
      shift
      ;;
    --table|-Table)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      translated="${translated}
-Table
$1"
      shift
      ;;
    --name|-Name)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      translated="${translated}
-Name
$1"
      shift
      ;;
    --name-prefix|-NamePrefix)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      translated="${translated}
-NamePrefix
$1"
      shift
      ;;
    --address|-Address)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      translated="${translated}
-Address
$1"
      shift
      ;;
    --range-ref|-RangeRef)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      translated="${translated}
-RangeRef
$1"
      shift
      ;;
    --value-json|-ValueJson)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      translated="${translated}
-ValueJson
$1"
      shift
      ;;
    --values-json|-ValuesJson)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      translated="${translated}
-ValuesJson
$1"
      shift
      ;;
    --refers-to|-RefersTo)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      translated="${translated}
-RefersTo
$1"
      shift
      ;;
    --state-root|-StateRoot)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      value="$(convert_path_arg "$1")"
      shift
      translated="${translated}
-StateRoot
$value"
      ;;
    --query-name|-QueryName)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      translated="${translated}
-QueryName
$1"
      shift
      ;;
    --apply|-Apply)
      translated="${translated}
-Apply"
      ;;
    --hidden|-Hidden)
      translated="${translated}
-Hidden"
      ;;
    --backend|-Backend)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      translated="${translated}
-Backend
$1"
      shift
      ;;
    --visible|-Visible)
      translated="${translated}
-Visible"
      ;;
    *)
      echo "error: unknown flag or argument: $arg" >&2
      echo "hint: run 'excel-foundry --help' for the supported CLI surface" >&2
      exit 2
      ;;
  esac
done

ps="$(detect_powershell || true)"
if [ -z "${ps}" ]; then
  echo "error: Excel COM automation is unavailable on this host" >&2
  echo "hint: run on Windows or inside WSL with Windows PowerShell and desktop Excel installed" >&2
  exit 127
fi

set --
oldifs="${IFS}"
IFS='
'
for item in $translated; do
  set -- "$@" "$item"
done
IFS="${oldifs}"

exec "$ps" -NoProfile -ExecutionPolicy Bypass -File "$ps1" "$@"

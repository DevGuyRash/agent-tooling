#!/usr/bin/env sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  excel-foundry <inspect|query|push|pull|roundtrip|smoke|refresh|bootstrap|plan|compare|sync> [options]
  excel-foundry <workbook|manifest|sheet|name|table|query|connection|chart|shape|picture|control|pivot|slicer|timeline|model|measure|relationship|hierarchy|kpi|perspective|automation|cell|range|graph-workbook|fabric-semantic-model|model-table|dax|semantic-artifact|solver|forecast-sheet|data-table> <action> [options]

Options:
  --manifest-path PATH
  --workbook-path PATH
  --other-workbook-path PATH
  --output-dir PATH
  --query-name NAME
  --surface LIST
  --backend NAME
  --mode NAME
  --sheet NAME
  --table NAME
  --name NAME
  --name-prefix NAME
  --connection NAME
  --chart NAME
  --pivot NAME
  --slicer NAME
  --timeline NAME
  --automation-type NAME
  --address A1
  --range-ref A1:B2
  --value-json JSON
  --values-json JSON
  --target-path PATH
  --target-format EXT
  --drive-id ID
  --item-id ID
  --item-path PATH
  --session-id ID
  --workspace-id ID
  --semantic-model-id ID
  --dataset-id ID
  --definition-dir PATH
  --format NAME
  --dax-query TEXT
  --spec-json JSON
  --spec-file PATH
  --refers-to FORMULA
  --hidden
  --state-root PATH
  --apply
  --dry-run | --what-if
  --persist-changes
  --hard-delete
  --destructive
  --deep
  --documentation
  --visible
  --help

This POSIX entrypoint is the user-facing CLI for bash, Git Bash, and WSL.
It validates arguments, normalizes paths, and bridges to the Windows
PowerShell backend for Excel COM automation.
EOF
}

script_path="$0"
case "$script_path" in
  */*) : ;;
  *) resolved="$(command -v -- "$script_path" 2>/dev/null || true)"; [ -n "$resolved" ] && script_path="$resolved" ;;
esac

if command -v readlink >/dev/null 2>&1; then
  while [ -L "$script_path" ]; do
    link="$(readlink "$script_path" 2>/dev/null || true)"
    [ -n "$link" ] || break
    case "$link" in
      /*) script_path="$link" ;;
      *) script_path="$(dirname -- "$script_path")/$link" ;;
    esac
  done
fi

script_dir="$(CDPATH='' cd -- "$(dirname -- "$script_path")" && pwd)"
ps1="${script_dir}/excel-foundry.ps1"

detect_powershell() {
  if [ "${EXCEL_WORKBOOK_SYNC_POWERSHELL:-}" ]; then
    printf '%s\n' "${EXCEL_WORKBOOK_SYNC_POWERSHELL}"
    return 0
  fi
  for candidate in pwsh powershell.exe powershell; do
    if command -v "$candidate" >/dev/null 2>&1; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

convert_path_arg() {
  value="$1"
  case "$value" in
    [A-Za-z]:\\*|[A-Za-z]:/*)
      printf '%s\n' "$value"
      return 0
      ;;
  esac
  if command -v wslpath >/dev/null 2>&1; then
    wslpath -w "$value"
    return 0
  fi
  if command -v cygpath >/dev/null 2>&1; then
    cygpath -w "$value"
    return 0
  fi
  printf '%s\n' "$value"
}

append_arg() {
  translated="${translated}
$1"
}

append_value_arg() {
  flag="$1"
  value="$2"
  translated="${translated}
$flag
$value"
}

pascal_flag() {
  printf '%s\n' "$1" | awk -F- '{
    out = ""
    for (i = 1; i <= NF; i++) {
      if ($i == "") continue
      out = out toupper(substr($i, 1, 1)) substr($i, 2)
    }
    print "-" out
  }'
}

subcommand="${1:-}"
case "$subcommand" in
  ""|-h|--help|help)
    usage
    exit 0
    ;;
  query)
    if [ "${2:-}" = "list" ]; then
      subcommand="query-list"
      shift 2
    else
      shift
    fi
    ;;
  inspect|push|pull|roundtrip|smoke|refresh|plan|compare|sync)
    shift
    ;;
  bootstrap)
    shift
    ;;
  workbook|manifest|sheet|name|table|connection|chart|shape|picture|control|pivot|slicer|timeline|model|measure|relationship|hierarchy|kpi|perspective|automation|cell|range|graph-workbook|fabric-semantic-model|model-table|dax|semantic-artifact|solver|forecast-sheet|data-table|what-if|scenario|goal-seek|formula-audit|calc-engine|cube-function|lambda-name|sparkline|xml-map|custom-xml|ole-object|external-data-range|workbook-view|threaded-comment|signature|encryption|sensitivity|privacy|pivot-chart|chart-sheet|office-script|office-script-live|excel-js-api|office-addin|addin-runtime)
    action="${2:-}"
    [ -n "$action" ] || { echo "error: missing action for resource command: $subcommand" >&2; exit 2; }
    subcommand="${subcommand}-${action}"
    shift 2
    ;;
  *)
    echo "error: unknown subcommand: $subcommand" >&2
    echo "hint: use one of inspect, query, push, pull, roundtrip, smoke, refresh, bootstrap, plan, compare, sync, or resource commands like 'workbook inspect'" >&2
    exit 2
    ;;
esac

set -- "$@"
translated="$subcommand"
while [ "$#" -gt 0 ]; do
  arg="$1"
  shift
  case "$arg" in
    --help|-h)
      usage
      exit 0
      ;;
    --manifest-path|-ManifestPath)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      value="$(convert_path_arg "$1")"
      shift
      append_value_arg "-ManifestPath" "$value"
      ;;
    --workbook-path|-WorkbookPath)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      value="$(convert_path_arg "$1")"
      shift
      append_value_arg "-WorkbookPath" "$value"
      ;;
    --other-workbook-path|-OtherWorkbookPath)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      value="$(convert_path_arg "$1")"
      shift
      append_value_arg "-OtherWorkbookPath" "$value"
      ;;
    --output-dir|-OutputDir)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      value="$(convert_path_arg "$1")"
      shift
      append_value_arg "-OutputDir" "$value"
      ;;
    --surface|-Surface|--mode|-Mode|--sheet|-Sheet|--table|-Table|--name|-Name|--name-prefix|-NamePrefix|--connection|-Connection|--chart|-Chart|--pivot|-Pivot|--slicer|-Slicer|--timeline|-Timeline|--automation-type|-AutomationType|--address|-Address|--range-ref|-RangeRef|--value-json|-ValueJson|--values-json|-ValuesJson|--target-format|-TargetFormat|--drive-id|-DriveId|--item-id|-ItemId|--item-path|-ItemPath|--session-id|-SessionId|--workspace-id|-WorkspaceId|--semantic-model-id|-SemanticModelId|--dataset-id|-DatasetId|--operation-id|-OperationId|--operation-location|-OperationLocation|--format|-Format|--dax-query|-DaxQuery|--spec-json|-SpecJson|--refers-to|-RefersTo|--query-name|-QueryName)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      case "$arg" in
        --*) flag="$(pascal_flag "${arg#--}")" ;;
        -*) flag="$arg" ;;
      esac
      append_value_arg "$flag" "$1"
      shift
      ;;
    --target-path|-TargetPath|--definition-dir|-DefinitionDir|--spec-file|-SpecFile|--state-root|-StateRoot)
      [ "$#" -gt 0 ] || { echo "error: missing value for $arg" >&2; exit 2; }
      value="$(convert_path_arg "$1")"
      shift
      case "$arg" in
        --*) flag="$(pascal_flag "${arg#--}")" ;;
        -*) flag="$arg" ;;
      esac
      append_value_arg "$flag" "$value"
      ;;
    --apply|-Apply)
      append_arg "-Apply"
      ;;
    --hidden|-Hidden)
      append_arg "-Hidden"
      ;;
    --visible|-Visible)
      append_arg "-Visible"
      ;;
    --dry-run|--what-if|-DryRun|-WhatIf)
      append_arg "-DryRun"
      ;;
    --persist-changes|-PersistChanges)
      append_arg "-PersistChanges"
      ;;
    --hard-delete|-HardDelete)
      append_arg "-HardDelete"
      ;;
    --destructive|-Destructive)
      append_arg "-Destructive"
      ;;
    --deep|-Deep)
      append_arg "-Deep"
      ;;
    --documentation|-Documentation)
      append_arg "-Documentation"
      ;;
    *)
      echo "error: unknown flag or argument: $arg" >&2
      echo "hint: run 'excel-foundry --help' for the supported CLI surface" >&2
      exit 2
      ;;
  esac
done

ps="$(detect_powershell || true)"
if [ -z "${ps}" ]; then
  echo "error: Excel COM automation is unavailable on this host" >&2
  echo "hint: run on Windows or inside WSL with Windows PowerShell and desktop Excel installed" >&2
  exit 127
fi

set --
oldifs="${IFS}"
IFS='
'
for item in $translated; do
  set -- "$@" "$item"
done
IFS="${oldifs}"

exec "$ps" -NoProfile -ExecutionPolicy Bypass -File "$ps1" "$@"
